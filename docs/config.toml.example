theme = "default"

[style]
mode = "plain"
separator = " | "

# ── Line 0: Model · Directory · Git · Session · OutputStyle ──────────────────
[[segments]]
id = "model"
enabled = true
line = 0

[segments.icon]
plain = "🤖"
nerd_font = ""

[segments.colors.icon]
c16 = 14

[segments.colors.text]
c16 = 14

[segments.styles]
text_bold = false

[segments.options]

[[segments]]
id = "directory"
enabled = true
line = 0

[segments.icon]
plain = "📁"
nerd_font = "󰉋"

[segments.colors.icon]
c16 = 11

[segments.colors.text]
c16 = 10

[segments.styles]
text_bold = false

[segments.options]

[[segments]]
id = "git"
enabled = true
line = 0

[segments.icon]
plain = "🌿"
nerd_font = "󰊢"

[segments.colors.icon]
c16 = 12

[segments.colors.text]
c16 = 12

[segments.styles]
text_bold = false

[segments.options]
show_sha = true
show_file_stats = true

[[segments]]
id = "session_name"
enabled = true
line = 0

[segments.icon]
plain = "◆"
nerd_font = "💬"

[segments.colors.icon]
c16 = 13

[segments.colors.text]
c16 = 13

[segments.styles]
text_bold = false

[segments.options]

[[segments]]
id = "session"
enabled = true
line = 0

[segments.icon]
plain = "⏱️"
nerd_font = "󱦻"

[segments.colors.icon]
c16 = 2

[segments.colors.text]
c16 = 2

[segments.styles]
text_bold = false

[segments.options]

[[segments]]
id = "output_style"
enabled = true
line = 0

[segments.icon]
plain = "🎯"
nerd_font = "󱋵"

[segments.colors.icon]
c16 = 6

[segments.colors.text]
c16 = 6

[segments.styles]
text_bold = false

[segments.options]

# ── Line 1: Context · Usage · Cost ───────────────────────────────────────────
[[segments]]
id = "context_window"
enabled = true
line = 1

[segments.icon]
plain = "Context"
nerd_font = "Context"

[segments.colors.icon]
c16 = 13

[segments.colors.text]
c16 = 13

[segments.styles]
text_bold = false

[segments.options]

[[segments]]
id = "usage"
enabled = true
line = 1

[segments.icon]
plain = "Usage"
nerd_font = "Usage"

[segments.colors.icon]
c16 = 14

[segments.colors.text]
c16 = 14

[segments.styles]
text_bold = false

[segments.options]
timeout = 2
api_base_url = "https://api.anthropic.com"
cache_duration = 180

[[segments]]
id = "cost"
enabled = true
line = 1

[segments.icon]
plain = "💰"
nerd_font = ""

[segments.colors.icon]
c16 = 3

[segments.colors.text]
c16 = 3

[segments.styles]
text_bold = false

[segments.options]

# ── Line 2: Tools ─────────────────────────────────────────────────────────────
[[segments]]
id = "tools"
enabled = true
line = 2

[segments.icon]
plain = "⚙️"
nerd_font = "⚙️"

[segments.colors.icon]
c16 = 14

[segments.colors.text]
c16 = 14

[segments.styles]
text_bold = false

[segments.options]
show_args = true  # 启用后每个工具显示具体调用参数（文件名/命令等）

# ── Line 3: Agents ────────────────────────────────────────────────────────────
[[segments]]
id = "agents"
enabled = true
